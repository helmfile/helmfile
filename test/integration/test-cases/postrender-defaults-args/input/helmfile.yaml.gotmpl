helmDefaults:
  postRenderer: {{ if eq (env "HELMFILE_HELM4") "1" }}echo-args{{ else }}./echo-args.bash{{ end }}
  postRendererArgs:
    - "{{ `{{ .Release.Name }}` }}"

releases:
  - name: foo
    chart: ../../../charts/raw
    values:
      - templates:
          - |
            apiVersion: v1
            kind: ConfigMap
            metadata:
              name: {{`{{ .Release.Name }}`}}-1
              namespace: {{`{{ .Release.Namespace }}`}}
            data:
              foo: FOO
  - name: bar
    chart: ../../../charts/raw
    values:
      - templates:
          - |
            apiVersion: v1
            kind: ConfigMap
            metadata:
              name: {{`{{ .Release.Name }}`}}-2
              namespace: {{`{{ .Release.Namespace }}`}}
            data:
              bar: BAR
